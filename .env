# ──────────────────────────────────────────────────────────────
# CONFIGURACIÓN GENERAL DEL CLUSTER
# ──────────────────────────────────────────────────────────────
SPARK_VERSION=3.5.1
MLFLOW_VERSION=v2.11.3
MARIADB_VERSION=10.11
HIVE_VERSION=3.1.3

# ──────────────────────────────────────────────────────────────
# CREDENCIALES Y SECRETOS
# ──────────────────────────────────────────────────────────────
# Base de Datos Metastore
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=metastore
MYSQL_USER=hive
MYSQL_PASSWORD=hivepassword

# Jupyter Config
JUPYTER_TOKEN=spark123

# GCP / BIGQUERY CENTRALIZADO
# Ruta en tu máquina física
GCP_KEY_LOCAL=/home/i2cat/.secrets/gcp-key-sparkml.json
# Ruta donde se montará dentro de los contenedores
GCP_KEY_CONTAINER=/opt/spark/gcp-key.json

# ──────────────────────────────────────────────────────────────
# RECURSOS DE TRABAJO (Tuning)
# ──────────────────────────────────────────────────────────────
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2
MLFLOW_TRACKING_URI=http://mlflow:5000
